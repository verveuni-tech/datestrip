# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="datestrip.vercel.app"

# Neon Postgres connection string for shared photobooth rooms on Vercel.
DATABASE_URL="postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Optional: Pusher Channels, used only to push the joint-capture countdown signal
# instantly instead of waiting for the next ~1s state poll. Free tier is plenty.
# If any of the 4 vars below are missing, the app silently falls back to
# poll-only sync — nothing breaks, it's just slightly less snappy.
# Get these from your Pusher app dashboard (dashboard.pusher.com -> App Keys).
PUSHER_APP_ID="MY_PUSHER_APP_ID"
PUSHER_KEY="MY_PUSHER_KEY"
PUSHER_SECRET="MY_PUSHER_SECRET"
PUSHER_CLUSTER="mt1"

# Client-side copies of the key/cluster above (Vite only exposes VITE_-prefixed
# vars to browser code). Must match PUSHER_KEY / PUSHER_CLUSTER exactly.
VITE_PUSHER_KEY="MY_PUSHER_KEY"
VITE_PUSHER_CLUSTER="mt1"
